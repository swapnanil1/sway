{
    "layer": "top",
    "position": "top",
    "spacing": 4,

//MODULES ON LEFT
    "modules-left": ["custom/pomodoro","custom/todo","sway/workspaces","sway/window","sway/mode"],
    "sway/workspaces": {
         "disable-scroll": true,
         "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{name}: {icon}",
         "format-icons": {
             "1": "’ē©",
             "2": "’äĪ",
             "3": "’äĀ",
             "4": "’å╝",
             "5": "’åČ",
             "urgent": "’ü¬",
             "default": "’äæ"
         }
     },
    "sway/window": {
        "max-length": 50
        },
    "sway/mode": {
        "format": "’Ś╝ {}",
        "max-length": 50,
        "always-on": true,
        "no-mode-message": "No Mode"
    },
    "custom/todo": {
        "exec": "~/.config/waybar/scripts/todo.sh",
        "return-type": "json",
        "format": " {} ’Ć║",
        "on-click": "alacritty -e nvim ~/todo.txt",
        "interval": 5,
    },
    "custom/pomodoro": {
      "exec": "i3-gnome-pomodoro status --format=waybar --show-seconds",
      "return-type": "json",
      "interval": 1,
      "format": " ’ēö {}",
      "format-icons": " ’ēö {}",
      "on-click": "i3-gnome-pomodoro start",
      "on-click-middle": "i3-gnome-pomodoro toggle",
      "on-click-right": "i3-gnome-pomodoro stop",
    },
//MODULES ON CENTRE
    "modules-center": [""],

//MODULES ON RIGHT
    "modules-right": ["keyboard-state","network","bluetooth","memory","cpu","temperature","custom/gpu-usage","pulseaudio","backlight","battery","clock","battery#timeleft","idle_inhibitor","custom/lock","custom/power","tray"],
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "’ĢĘ",
            "unlocked": "’ĢĘ"
        }
    },
   "network": {
        "interface": "wlan0", // This is the magic line
        "format-wifi": "’ć½  on",
       // "format-wifi": "’ć½  ’ĆÖ {bandwidthDownBytes} ’éō {bandwidthUpBytes}",
        "format-ethernet": "’ĆÖ  on",
       // "format-ethernet": "’ĆÖ {bandwidthDownBytes} ’éō {bandwidthUpBytes}",
        "format-linked": "(No IP)",
        "format-disconnected": "’ü▓",
        "on-click": "alacritty -e nmtui",
        "tooltip": false,
        "interval": 3
    },
    "bluetooth": {
      "controller": "controller1", // specify the alias of the controller if there are more than 1 on the system
      "format": "’Ŗö {status}|",
      "format-disabled": "", // an empty format will hide the module
      "format-connected": "’Ŗö {num_connections}|",
      "tooltip-format": "{controller_alias}\t{controller_address}",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "on-click": "alacritty -e bluetuith",
    },
    "cpu": {
        "interval": 10, 
        "format": "’ŗø {usage}%"
    },
    "memory": {
        "interval": 10,
        "format": "’ł│ {}%"
    },
   "temperature": {
        "thermal-zone": 1,
        "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
        "critical-threshold": 80,
        "format-critical": "’ŗē {temperatureC}┬░C|",
        "format": "’ŗē{temperatureC}┬░C|"
    },
   "pulseaudio": {
        "scroll-step": 5, // %,
        "format": "{icon}{volume}% {format_source}",
        "format-bluetooth": "{icon}’Ŗö {volume}% {format_source}",
        "format-bluetooth-muted": "’Ć”{icon}’Ŗö {format_source}",
        "format-muted": "’Ć”{format_source}",
        "format-source": "’ä░{volume}%",
        "format-source-muted": "’ä▒ ",
        "format-icons": {
            "headphone": "’Ćź ",
            "default": ["’Ć”", "’Ć¦", "’Ć© "]
        },
        "on-click": "pavucontrol",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "backlight": {
      "device": "intel_backlight",
      "format": "’åģ {percent}%"
    },
    "battery": {
      "bat": "BAT0",
        "format": "{icon} {capacity}%",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
        "format-time": "{H}h{M}m",
        "format-charging": "<span font='JetBrainsMono Nerd Font'>’ā¦</span>  <span font='JetBrainsMono Nerd Font 11'>{icon}</span>  {capacity}% - {time} ",
        "format-full": "<span font='JetBrainsMono Nerd Font'>’ā¦</span>  <span font='JetBrainsMono Nerd Font 11'>{icon}</span>  Charged |",
        "interval": 30,
        "states": {
            "warning": 10,
            "critical": 5,
        },
        "tooltip": false,
        "on-click": "2"
    },
    "clock": {
        "timezone": "Asia/Kolkata",
        "format": "{:%I:%M%p}",
        "format-alt": "{:%A, %B %d, %Y (%R)} ’ü│ ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              },
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "battery#timeleft": {
      "bat": "BAT0",
        "format": "+<span font='JetBrainsMono Nerd Font 12'>{time}</span>|",
        "format-time": "{H}H:{M}M",
        "interval": 30,
        "tooltip": false,
        "on-click": "2"
    },
   "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü« ",
            "deactivated": "’ü░ "
        }
    },
    "custom/lock": {
        "format": "’ĢĘ ",
        "tooltip": false,
        "on-click": "swaylock -f -i ~/Pictures/Wallpapers/lockscreen.jpg"
    },
     "custom/power":{
      "tooltip": false,
        "format":"’Ćæ ", "on-click":"swaynag -t warning -m 'power menu options' -b 'restart' 'swaymsg exec systemctl reboot' -b 'shutdown' 'swaymsg exec systemctl poweroff' -b 'restart to bios' 'systemctl reboot --firmware-setup'"
    },
    "tray": {
        //"icon-size": 21,
        "spacing": 10
    },
}
