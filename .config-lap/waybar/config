{
    "layer": "top",
    "position": "top",
    "width": 0,//Change to res
    "spacing": 10,

//MODULES ON LEFT
    "modules-left": ["sway/workspaces","sway/window","sway/mode"],
    "sway/workspaces": {
         "disable-scroll": true,
         "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{name}: {icon}",
         "format-icons": {
             "1": "пҺё",
             "2": "оҒә",
             "3": "п„ ",
             "4": "пүЁ",
             "5": "пҶ¶",
             "urgent": "пҒӘ",
             "default": "п„‘"
         }
     },
    "sway/window": {
        "max-length": 50
        },
    "sway/mode": {
        "format": "п—ј {}",
        "max-length": 50,
        "always-on": true,
        "no-mode-message": "No Mode"
    },
//MODULES ON CENTRE
    "modules-center": [""],

//MODULES ON RIGHT
    "modules-right": ["idle_inhibitor","custom/pomodoro","bluetooth","network","cpu","memory","clock","pulseaudio","battery","custom/lock","custom/power","tray"],
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пҒ® ",
            "deactivated": "пҒ° "
        }
    },
    "pulseaudio": {
        "scroll-step": 5, // %,
        "format": "| {icon}{volume}% {format_source}",
        "format-bluetooth": "| {icon}пҠ” {volume}% {format_source}",
        "format-bluetooth-muted": "| пҖҰ {icon}пҠ” {format_source}",
        "format-muted": "| пҖҰ {format_source}",
        "format-source": "п„° {volume}%",
        "format-source-muted": "п„ұ ",
        "format-icons": {
            "headphone": "пҖҘ ",
            "default": ["пҖҰ", "пҖ§", "пҖЁ "]
        },
        "on-click": "pavucontrol",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "custom/pomodoro": {
      "exec": "i3-gnome-pomodoro status --format=waybar --show-seconds",
      "return-type": "json",
      "interval": 1,
      "format": "{}",
      "on-click": "i3-gnome-pomodoro start",
      "on-click-middle": "i3-gnome-pomodoro toggle",
      "on-click-right": "i3-gnome-pomodoro stop",
    },
    "bluetooth": {
      "controller": "controller1", // specify the alias of the controller if there are more than 1 on the system
      "format": "| пҠ” {status}",
      "format-disabled": "", // an empty format will hide the module
      "format-connected": "| пҠ” {num_connections}",
      "tooltip-format": "{controller_alias}\t{controller_address}",
      "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
      "on-click": "alacritty -e bluetuith",
    },
    "network": {
        "interface": "wlan0", // This is the magic line
        "format-wifi": "пҮ«  on",
       // "format-wifi": "пҮ«  пҖҷ {bandwidthDownBytes} пӮ“ {bandwidthUpBytes}|",
        "format-ethernet": "пҖҷ  on",
       // "format-ethernet": "пҖҷ {bandwidthDownBytes} пӮ“ {bandwidthUpBytes}|",
        "format-linked": "(No IP)",
        "format-disconnected": "пҒІ",
        "on-click": "alacritty -e nmtui",
        "tooltip": false,
        "interval": 3
    },
    "cpu": {
        "interval": 10, 
        "format": "| пӢӣ {usage}%",
        "on-click": "alacritty -e bashtop",
    },
    "memory": {
        "interval": 10,
        "format": "пҲі {}% |",
        "on-click": "alacritty -e htop",
    },
   "temperature#cpu": {
        "thermal-zone": 1,
        "hwmon-path": "/sys/class/hwmon/hwmon4/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{icon} {temperatureC}В°C|",
        "format": "{icon} {temperatureC}В°C |",
        "format-icons": ["пӢҠ", "пӢү", "пӢҮ"]
    },
    "clock": {
        "timezone": "Asia/Kolkata",
        "format": "{:%I:%M%p}",
        "format-alt": "{:%A, %B %d, %Y (%R)} пҒі ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "custom/lock": {
        "format": "пҖЈ ",
	"tooltip": false,
        "on-click": "swaylock -f -i ~/Pictures/Wallpapers/lockscreen.jpg"
    },
     "custom/power":{
	"tooltip": false,
        "format":"пҖ‘ |", "on-click":"swaynag -t warning -m 'Power Menu Options' -b 'Restart' 'swaymsg exec systemctl reboot' -b 'Shutdown' 'swaymsg exec systemctl poweroff' -b 'Restart to BIOS' 'systemctl reboot --firmware-setup'"
    },
    "battery": {
	"bat": "BAT0",
        "format": "<span font='JetBrainsMono Nerd Font 11'>{icon}</span> {capacity}% - {time} |",
        "format-icons": ["пү„", "пүғ", "пүӮ", "пүҒ", "пүҖ"],
        "format-time": "{H}h{M}m",
        "format-charging": "<span font='JetBrainsMono Nerd Font'>пғ§</span>  <span font='JetBrainsMono Nerd Font 11'>{icon}</span>  {capacity}% - {time} ",
        "format-full": "<span font='JetBrainsMono Nerd Font'>пғ§</span>  <span font='JetBrainsMono Nerd Font 11'>{icon}</span>  Charged |",
        "interval": 30,
        "states": {
            "warning": 10,
            "critical": 5,
        },
        "tooltip": false,
        "on-click": "2"
    },
    "tray": {
        //"icon-size": 21,
        "spacing": 10
    },
}
