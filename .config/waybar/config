{
    "layer": "top",
    "position": "top",
    "width": 1910,//Change to res
    "spacing": 10,

//MODULES ON LEFT
    "modules-left": ["sway/workspaces","sway/window","sway/mode"],
    "sway/workspaces": {
         "disable-scroll": true,
         "all-outputs": true,
         "warp-on-scroll": false,
         "format": "{name}: {icon}",
         "format-icons": {
             "1": "’ÄĖ",
             "2": "Ņü║",
             "3": "’äĀ",
             "4": "’ē©",
             "5": "’åČ",
             "urgent": "’ü¬",
             "default": "’äæ"
         }
     },
    "sway/window": {
        "max-length": 50
        },
    "sway/mode": {
        "format": "’Ś╝ {}",
        "max-length": 50,
        "always-on": true,
        "no-mode-message": "No Mode"
    },
//MODULES ON CENTRE
    "modules-center": [""],

//MODULES ON RIGHT
    "modules-right": ["idle_inhibitor","keyboard-state","network","cpu","memory","custom/gpu-usage","temperature","temperature#cpu","clock","pulseaudio","custom/lock","custom/power","tray"],
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "’ĆŻ",
            "unlocked": "’é£"
        }
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü« ",
            "deactivated": "’ü░ "
        }
    },
    "pulseaudio": {
        "scroll-step": 5, // %,
        "format": "| {icon}{volume}% {format_source}",
        "format-bluetooth": "| {icon}’Ŗö {volume}% {format_source}",
        "format-bluetooth-muted": "| ’Ć” {icon}’Ŗö {format_source}",
        "format-muted": "| ’Ć” {format_source}",
        "format-source": "’ä░ {volume}%",
        "format-source-muted": "’ä▒ ",
        "format-icons": {
            "headphone": "’Ćź ",
            "default": ["’Ć”", "’Ć¦", "’Ć© "]
        },
        "on-click": "pavucontrol",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },
    "cpu": {
        "interval": 10, 
        "format": "’ŗø {usage}%"
    },
    "memory": {
        "interval": 10,
        "format": "’ł│ {}%"
    },
    "custom/gpu-usage": {
        "exec": "cat /sys/class/hwmon/hwmon2/device/gpu_busy_percent",
        "format": "’éØ {}%",
        "return-type": "",
        "interval": 1 
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        "format-critical": "| GPU {temperatureC}┬░C",
        "format": "| GPU {temperatureC}┬░C",
        "format-icons": ["’ŗŖ", "’ŗē", "’ŗć"]
    },
   "temperature#cpu": {
        "thermal-zone": 1,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{icon} CPU {temperatureC}┬░C |",
        "format": "{icon} CPU {temperatureC}┬░C |",
        "format-icons": ["’ŗŖ", "’ŗē", "’ŗć"]
    },
    "network": {
        "interface": "enp34s0", // This is the magic line
        "format-wifi": "’ć½  ’ĆÖ {bandwidthDownBits} ’éō {bandwidthUpBits} |",
        "format-ethernet": "’ĆÖ {bandwidthDownBits} ’éō {bandwidthUpBits} |",
        "format-linked": "(No IP)",
        "format-disconnected": "’ü▓",
        "on-click": "alacritty -e nmtui",
        "tooltip": false,
        "interval": 3
    },
    "clock": {
        "timezone": "Asia/Kolkata",
        "format": "{:%I:%M%p}",
        "format-alt": "{:%A, %B %d, %Y (%R)} ’ü│ ",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "right",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span color='#ffead3'><b>{}</b></span>",
                              "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                              "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "custom/lock": {
        "format": "| ’ĆŻ",
	"tooltip": false,
        "on-click": "swaylock -f -i ~/Pictures/Wallpapers/lockscreen.jpg"
    },
     "custom/power":{
	"tooltip": false,
        "format":"’Ćæ |", "on-click":"swaynag -t warning -m 'Power Menu Options | Remember to Switch Off your Keyboard after Shutdown' -b 'Restart' 'swaymsg exec systemctl reboot' -b 'Shutdown | Keyboard' 'swaymsg exec systemctl poweroff'"
    },
    "tray": {
        //"icon-size": 21,
        "spacing": 10
    },
}
